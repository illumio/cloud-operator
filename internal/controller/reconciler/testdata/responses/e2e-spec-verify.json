{
  "specs":  [
    {
      "endpointSelector":  {
        "matchLabels":  {
          "app":  "backend"
        }
      },
      "description":  "Allow HTTP ingress from frontend, deny all egress",
      "enableDefaultDeny":  {
        "ingress":  true,
        "egress":  true
      },
      "ingress":  [
        {
          "fromEndpoints":  {
            "items":  [
              {
                "matchLabels":  {
                  "app":  "frontend"
                }
              }
            ]
          },
          "toPorts":  [
            {
              "ports":  [
                {
                  "port":  "80",
                  "protocol":  "TCP"
                },
                {
                  "port":  "443",
                  "protocol":  "TCP"
                }
              ]
            }
          ]
        }
      ],
      "egress":  [
        {}
      ]
    }
  ]
}
