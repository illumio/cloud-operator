{
  "specs":  [
    {
      "endpointSelector":  {
        "matchLabels":  {
          "app":  "external-client"
        }
      },
      "egress":  [
        {
          "toEndpoints":  {
            "items":  [
              {
                "matchLabels":  {
                  "k8s-app":  "kube-dns",
                  "k8s:io.kubernetes.pod.namespace":  "kube-system"
                }
              }
            ]
          },
          "toPorts":  [
            {
              "ports":  [
                {
                  "port":  "53",
                  "protocol":  "UDP"
                }
              ]
            }
          ]
        },
        {
          "toFQDNs":  [
            {
              "matchName":  "my-remote-service.com"
            },
            {
              "matchPattern":  "*.api.example.com"
            }
          ],
          "toPorts":  [
            {
              "ports":  [
                {
                  "port":  "443",
                  "protocol":  "TCP"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
