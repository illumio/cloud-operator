{
  "specs":  [
    {
      "endpointSelector":  {
        "matchLabels":  {
          "app":  "backend"
        }
      },
      "description":  "Allow ingress from frontend namespace to backend pods",
      "ingress":  [
        {
          "fromEndpoints":  {
            "items":  [
              {
                "matchLabels":  {
                  "k8s:io.kubernetes.pod.namespace":  "frontend"
                }
              }
            ]
          },
          "toPorts":  [
            {
              "ports":  [
                {
                  "port":  "8080",
                  "protocol":  "TCP"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
