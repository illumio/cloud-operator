{
  "specs":  [
    {
      "endpointSelector":  {
        "matchLabels":  {
          "app":  "web"
        }
      },
      "ingress":  [
        {
          "fromEndpoints":  {
            "items":  [
              {
                "matchLabels":  {
                  "app":  "frontend"
                }
              }
            ]
          },
          "toPorts":  [
            {
              "ports":  [
                {
                  "port":  "80",
                  "protocol":  "TCP"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "endpointSelector":  {
        "matchLabels":  {
          "app":  "api"
        }
      },
      "egress":  [
        {
          "toEndpoints":  {
            "items":  [
              {
                "matchLabels":  {
                  "app":  "database"
                }
              }
            ]
          },
          "toPorts":  [
            {
              "ports":  [
                {
                  "port":  "5432",
                  "protocol":  "TCP"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
