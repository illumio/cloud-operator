{
  "specs":  [
    {
      "endpointSelector":  {
        "matchLabels":  {
          "k8s-app":  "kube-dns",
          "k8s:io.kubernetes.pod.namespace":  "kube-system"
        }
      },
      "description":  "Allow ingress to kube-dns from all Cilium managed endpoints",
      "ingress":  [
        {
          "fromEndpoints":  {
            "items":  [
              {}
            ]
          },
          "toPorts":  [
            {
              "ports":  [
                {
                  "port":  "53",
                  "protocol":  "UDP"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
